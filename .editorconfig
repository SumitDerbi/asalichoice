# EditorConfig — https://editorconfig.org/
# Top-level config for the AsliChoice monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python — 4-space indent per PEP 8
[*.{py,pyi}]
indent_size = 4

# JavaScript / TypeScript / JSON / YAML / CSS / HTML / Markdown — 2-space
[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,yml,yaml,css,scss,html,md}]
indent_size = 2

# Makefiles require tabs
[{Makefile,makefile,*.mk}]
indent_style = tab

# Markdown — keep trailing whitespace (used for hard line breaks)
[*.md]
trim_trailing_whitespace = false
