# =============================================================================
# AsliChoice storefront (Wagtail) — .env SAMPLE
#
# Copy to:  ~/deploy_config/<env_name>/<env_name>.site.env
# Example:  ~/deploy_config/staging/staging.site.env
# =============================================================================

# --- Django core --------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=asalichoice.example,www.asalichoice.example
CSRF_TRUSTED_ORIGINS=https://asalichoice.example,https://www.asalichoice.example

# --- Database (shared with backend) -------------------------------------------
DATABASE_NAME=cpaneluser_asalichoice
DATABASE_USER=cpaneluser_asalichoice
DATABASE_PASSWORD=replace-me
DATABASE_HOST=localhost
DATABASE_PORT=3306

# --- Static / media -----------------------------------------------------------
STATIC_ROOT=/home/USER/public_html/asalichoice/static/
MEDIA_ROOT=/home/USER/public_html/asalichoice/media/
STATIC_URL=/static/
MEDIA_URL=/media/

# --- API endpoint the storefront calls (server-side) --------------------------
BACKEND_API_URL=https://api.asalichoice.example/api/v1/

# --- Email --------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@asalichoice.example
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=AsliChoice <no-reply@asalichoice.example>
