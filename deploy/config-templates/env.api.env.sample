# =============================================================================
# AsliChoice backend API — .env SAMPLE
#
# Copy to:  ~/deploy_config/<env_name>/<env_name>.api.env
# Example:  ~/deploy_config/staging/staging.api.env
#
# This file is copied verbatim into <APP_DIR_BACKEND>/.env on each deploy and
# loaded by django-environ. Do NOT commit real secrets.
# =============================================================================

# --- Django core --------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=api.asalichoice.example
CSRF_TRUSTED_ORIGINS=https://api.asalichoice.example,https://asalichoice.example

# --- Database (MySQL on the same cPanel host) ---------------------------------
DATABASE_NAME=cpaneluser_asalichoice
DATABASE_USER=cpaneluser_asalichoice
DATABASE_PASSWORD=replace-me
DATABASE_HOST=localhost
DATABASE_PORT=3306

# --- Cache / broker -----------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# --- Static / media -----------------------------------------------------------
STATIC_ROOT=/home/USER/public_html/asalichoice/static-api/
MEDIA_ROOT=/home/USER/public_html/asalichoice/media/
STATIC_URL=/static-api/
MEDIA_URL=/media/

# --- Email --------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@asalichoice.example
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=AsliChoice <no-reply@asalichoice.example>

# --- CORS (admin-ui served from a different origin) ---------------------------
CORS_ALLOWED_ORIGINS=https://asalichoice.example,https://admin.asalichoice.example
