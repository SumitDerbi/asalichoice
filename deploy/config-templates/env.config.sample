# =============================================================================
# AsliChoice deploy config — SAMPLE
#
# Copy to:  ~/deploy_config/<env_name>/<env_name>.config
# Example:  ~/deploy_config/staging/staging.config
#
# Loaded by deploy.sh via `eval`. Use bash-compatible syntax (no spaces around
# '='). Tildes are expanded; trailing slashes are stripped.
# =============================================================================

# --- Repository checkout on the cPanel host -----------------------------------
GIT_DIR=~/repositories/asalichoice

# --- Live app directories -----------------------------------------------------
APP_DIR_BACKEND=~/asalichoice_api
APP_DIR_STOREFRONT=~/public_html/asalichoice
APP_DIR_ADMIN_UI=~/public_html/asalichoice/admin

# --- Virtualenvs (cPanel "Setup Python App") ---------------------------------
VIRTUALENV_BACKEND=/home/USER/virtualenv/asalichoice_api/3.11/
VIRTUALENV_STOREFRONT=/home/USER/virtualenv/asalichoice_site/3.11/
ACTIVATE_BACKEND=$VIRTUALENV_BACKEND/bin/activate
ACTIVATE_STOREFRONT=$VIRTUALENV_STOREFRONT/bin/activate

# --- Django settings modules --------------------------------------------------
DJANGO_SETTINGS_BACKEND=config.settings.production
DJANGO_SETTINGS_STOREFRONT=config.settings.production

# --- Requirements files (relative to each app dir) ----------------------------
REQUIREMENTS_FILE_BACKEND=requirements/production.txt
REQUIREMENTS_FILE_STOREFRONT=requirements/production.txt

# --- Static / media roots -----------------------------------------------------
STATIC_ROOT_BACKEND=~/public_html/asalichoice/static-api/
STATIC_ROOT_STOREFRONT=~/public_html/asalichoice/static/
MEDIA_ROOT=~/public_html/asalichoice/media/

# --- Backups ------------------------------------------------------------------
DB_BACKUP_PATH=~/backups/asalichoice/

# --- Node (for admin-ui Vite + storefront Tailwind builds) --------------------
# cPanel "Setup Node.js App" gives you a per-app nodevenv. Point this at the
# bin directory whose `node` and `npm` you want to use during the build.
NODE_BIN=/home/USER/nodevenv/admin-ui/20/bin

# --- Health check URLs (optional; deploy aborts on non-200) -------------------
HEALTHCHECK_BACKEND_URL=https://api.asalichoice.example/api/v1/health/
HEALTHCHECK_STOREFRONT_URL=https://asalichoice.example/

# --- Env-file overrides (optional; default = ~/deploy_config/<env>/<env>.{api,site}.env)
# API_ENV_FILE=~/deploy_config/staging/staging.api.env
# SITE_ENV_FILE=~/deploy_config/staging/staging.site.env
