{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "screen",
          "variants",
          "responsive"
        ]
      }
    ],
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "import-notation": "string"
  },
  "ignoreFiles": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/staticfiles/**",
    "storefront/theme/static/theme/css/output.css"
  ]
}
