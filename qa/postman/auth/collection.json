{
  "info": {
    "name": "AsliChoice — Auth",
    "_postman_id": "9c2f6a1e-1d34-4f0f-8a4a-006-auth-skeleton",
    "description": "JWT auth surface delivered in plan 006-auth-skeleton.md.\n\nUse the `local` environment file in `qa/postman/local.env.json`.\n\nFlow:\n1. `Login` populates `access` + `refresh` variables.\n2. `Me` and `Refresh` rely on those variables.\n3. `Logout` blacklists the refresh token and clears variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/login/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.environment.set('access', data.access);",
              "pm.environment.set('refresh', data.refresh);"
            ]
          }
        }
      ]
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
        "url": {
          "raw": "{{baseUrl}}/auth/me/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me", ""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('returns the authenticated user', () => {",
              "  const u = pm.response.json();",
              "  pm.expect(u.email).to.eql(pm.environment.get('email'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/refresh/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.environment.set('access', pm.response.json().access);"
            ]
          }
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/logout/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "logout", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('205 Reset Content', () => pm.response.to.have.status(205));",
              "pm.environment.unset('access');",
              "pm.environment.unset('refresh');"
            ]
          }
        }
      ]
    },
    {
      "name": "Sessions (List)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
        "url": {
          "raw": "{{baseUrl}}/auth/sessions/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "sessions", ""]
        }
      }
    },
    {
      "name": "Sessions (Revoke)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/sessions/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "sessions", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jti\": \"{{session_jti}}\"\n}"
        }
      }
    },
    {
      "name": "Invite User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/invite/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "invite", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"invitee@example.test\",\n  \"branch_id\": 1,\n  \"roles\": [\"manager\"]\n}"
        }
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/forgot-password/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "forgot-password", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"admin@example.test\"\n}"
        }
      }
    },
    {
      "name": "Reset Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/auth/reset-password/",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "reset-password", ""]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"newpassword123\"\n}"
        }
      }
    }
  ]
}
