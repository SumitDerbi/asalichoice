          }
        }
      ]
    },
    {
      "name": "List barcodes",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
        "url": {
          "raw": "{{baseUrl}}/catalog/barcodes/",
          "host": ["{{baseUrl}}"],
          "path": ["catalog", "barcodes", ""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "if (body.results && body.results.length > 0) {",
              "  pm.environment.set('barcodeValue', body.results[0].value);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Resolve barcode (missing)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
        "url": {
          "raw": "{{baseUrl}}/catalog/barcodes/resolve/?value=__nope__",
          "host": ["{{baseUrl}}"],
          "path": ["catalog", "barcodes", "resolve", ""],
          "query": [{ "key": "value", "value": "__nope__" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('404 Not Found', () => pm.response.to.have.status(404));",
              "pm.test('CAT-040 error code', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.error && body.error.code).to.eql('CAT-040');",
              "});"
            ]
          }
        }
      ]
    },
