# =============================================================================
# AsliChoice — .env.example
# -----------------------------------------------------------------------------
# This file lists ALL environment variables introduced across the monorepo.
# Each module/agent appends its own variables in subsequent plan steps.
#
# NOTE: Real `.env` files are NEVER committed. In production/staging they live
#       under `~/deploy_config/<env>/` on the deploy host and are symlinked or
#       sourced by `deploy.sh`. For local development, copy this file to
#       `.env` at the appropriate location and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
# (modules append below this line)

# -----------------------------------------------------------------------------
# Backend — Django (plan 001-backend-django-setup)
# -----------------------------------------------------------------------------
# Copy this block into `backend/.env` for local development. Real values in
# production live under `~/deploy_config/<env>/<env>.env` on the deploy host.

# Core
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Kolkata
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Database — primary engine is MySQL. Set DB_ENGINE=sqlite to use SQLite
# locally (recommended for first-time setup). When DB_PASSWORD is empty and
# DB_ENGINE is not "mysql", development.py automatically falls back to SQLite.
DB_ENGINE=mysql
DB_NAME=asalichoice
DB_USER=asalichoice
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# CORS — comma-separated list of origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# JWT (SimpleJWT) — lifetimes in minutes.
JWT_ACCESS_MINUTES=15
JWT_REFRESH_MINUTES=10080
JWT_SIGNING_KEY=

# Production-only security headers (overridable).
SECURE_HSTS_SECONDS=31536000

# -----------------------------------------------------------------------------
# Storefront — Wagtail (plan 003-website-wagtail-setup)
# -----------------------------------------------------------------------------
# Copy this block into `storefront/.env` for local development. Real values
# in production live under `~/deploy_config/<env>/<env>.env` on the deploy
# host. The storefront uses an independent venv + Django process and talks
# to the backend over HTTP only (never the DB directly).

# Core
# SECRET_KEY=change-me-to-a-50-char-random-string
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# TIME_ZONE=Asia/Kolkata
# APP_VERSION=0.1.0
# LOG_LEVEL=INFO

# Public-facing site metadata (surfaced in <title>, meta description, JSON-LD).
SITE_NAME=AsliChoice
SITE_DESCRIPTION=AsliChoice — curated omnichannel storefront.

# Database — separate from the backend's DB. SQLite fallback applies when
# DB_PASSWORD is empty and DB_ENGINE != "mysql".
# DB_ENGINE=mysql
# DB_NAME=asalichoice_storefront
# DB_USER=asalichoice_storefront
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_CONN_MAX_AGE=60

# Backend API (consumed server-side by the storefront, never proxied raw).
BACKEND_API_URL=http://localhost:8000/api/v1
BACKEND_API_TIMEOUT=5.0

# Wagtail admin absolute URL — used in admin emails / notifications.
WAGTAILADMIN_BASE_URL=http://localhost:8001

